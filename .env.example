# Supabase project settings (Dashboard → Project Settings → API)
# Use the project base URL (no /rest/v1/ path). Example: https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# The service role key is SECRET — never put VITE_ prefix on this one,
# and never commit it. It's only used by the small local API server
# (see server/ folder) so it's never bundled into the browser app. The
# browser never talks to Supabase directly — all reads and writes go
# through the Express API, which is why no anon key is needed here.
SUPABASE_SERVICE_ROLE_KEY=

# Shared password for /admin access (simple gate, not real user accounts)
ADMIN_PASSWORD=

# Port the local Express API server runs on (Vite proxies /api to this)
API_PORT=
